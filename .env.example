# In dev with Vite proxy use: /api/v1/ . For production set to your API origin (e.g. https://api.yourdomain.com/api/v1/)
VITE_API_BASE_URL=http://localhost:3000/api/v1/

# Firebase Cloud Messaging (PRD 16 — Push notifications)
# From Firebase Console: Project Settings > General > Your apps > Web app config
# VAPID key: Project Settings > Cloud Messaging > Web Push certificates
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
# VITE_FIREBASE_APP_ID=1:123456789:web:abc
# VITE_FIREBASE_VAPID_KEY=your-web-push-vapid-key

# Service worker: public/firebase-messaging-sw.js is generated from public/firebase-messaging-sw.template.js
# using the VITE_FIREBASE_* vars above (npm run dev / npm run build runs the generator). The generated
# file is in .gitignore — do not push it. If firebase-messaging-sw.js was ever committed, run:
#   git rm --cached public/firebase-messaging-sw.js
